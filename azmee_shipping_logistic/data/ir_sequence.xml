<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="seq_azmee_spb" model="ir.sequence">
            <field name="name">SPB</field>
            <field name="code">seq.azmee.spb</field>
            <field name="prefix">SPB/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
         <record id="seq_azmee_pl_issue" model="ir.sequence">
            <field name="name">PL Issue</field>
            <field name="code">seq.packing.list.issue</field>
            <field name="prefix">PLI/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_azmee_shipment" model="ir.sequence">
            <field name="name">Shipment</field>
            <field name="code">seq.shipment</field>
            <field name="prefix">SH/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_azmee_pl_receipt" model="ir.sequence">
            <field name="name">PL Receipt</field>
            <field name="code">seq.packing.list.receipt</field>
            <field name="prefix">PLR/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
