<?xml version="1.0" encoding="utf8" ?>
<odoo>
    <record id="azmee_vehicle_brand_form_view" model="ir.ui.view">
        <field name="name">azmee.vehicle.brand.form.view</field>
        <field name="model">azmee.vehicle.brand</field>
        <field name="arch" type="xml">
            <form string="Brand">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <grouup>
                        <field name="vehicle_ids"></field>
                    </grouup>
                </sheet>
            </form>
        </field>
    </record>

    <record id="azmee_vehicle_brand_list_view" model="ir.ui.view">
        <field name="name">azmee.vehicle.brand.list.view</field>
        <field name="model">azmee.vehicle.brand</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="azmee_vehicle_brand_action_view" model="ir.actions.act_window">
        <field name="name">Brand</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">azmee.vehicle.brand</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                There is no vehicle brand!
              </p><p>
                Click create to add one.
              </p>
            </field>
    </record>

    <menuitem id="azmee_vehicle_brand_menu" name="Brand" parent="master_data_menu" action="azmee_vehicle_brand_action_view" sequence="20"/>
</odoo>