<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="pl_receipt_form_view" model="ir.ui.view">
          <field name="name">pl.receipt.form.view</field>
          <field name="model">packing.list.receipt</field>
          <field name="arch" type="xml">
              <form string="Packing List Receipt">
                  <header>
                      <button name="action_done" string="Done" class="oe_highlight" invisible="state != 'draft'" type="object"/>
                      <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                  </header>
                  <sheet>
                      <div class="oe_title">
                          <label for="name" class="oe_edit_only"/>
                          <h1>
                              <field name="name" placeholder="......"/>
                          </h1>
                      </div>
                      <group>
                          <group>
                              <field name="receiver_name" readonly="state == 'done'"/>
                              <field name="receiver_date" readonly="state == 'done'"/>
                          </group>
                          <group>
                              <field name="shipment_ids" widget="many2many_tags" readonly="state == 'done'"/>
                          </group>
                      </group>
                      <group>
                          <field name="line_ids" nolabel="1" readonly="state == 'done'">
                              <list editable="bottom" create="0">
                                  <field name="pl_issue_line_id" column_invisible="True"/>
                                  <field name="pl_issue_id"/>
                                  <field name="spb_id"/>
                                  <field name="product_id"/>
                                  <field name="qty_spb"/>
                                  <field name="qty_issue"/>
                                  <field name="qty_receipt"/>
                              </list>
                          </field>
                      </group>
                  </sheet>
              </form>
          </field>
        </record>

        <record id="pl_receipt_list_view" model="ir.ui.view">
            <field name="name">pl.receipt.list.view</field>
            <field name="model">packing.list.receipt</field>
            <field name="arch" type="xml">
                <list string="Packing List Receipt">
                    <field name="name"/>
                    <field name="receiver_name"/>
                    <field name="receiver_date"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
                </list>
            </field>
        </record>

        <record id="pl_receipt_action_view" model="ir.actions.act_window">
            <field name="name">Packing List Receipt</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">packing.list.receipt</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="pl_receipt_menu" name="Packing List Receipt" parent="dokumen_menu" action="pl_receipt_action_view" sequence="20"/>
    </data>
</odoo>