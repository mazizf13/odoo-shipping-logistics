<?xml version="1.0" encoding="utf8" ?>
<odoo>
    <record id="azmee_vehicle_type_form_view" model="ir.ui.view">
        <field name="name">azmee.vehicle.type.form.view</field>
        <field name="model">azmee.vehicle.type</field>
        <field name="arch" type="xml">
            <form string="Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <field name="brand_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="azmee_vehicle_type_list_view" model="ir.ui.view">
        <field name="name">azmee.vehicle.type.list.view</field>
        <field name="model">azmee.vehicle.type</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="azmee_vehicle_type_action_view" model="ir.actions.act_window">
        <field name="name">Type</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">azmee.vehicle.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                There is no vehicle type!
              </p><p>
                Click create to add one.
              </p>
            </field>
    </record>

    <menuitem id="azmee_vehicle_type_menu" name="Type" parent="azmee_shipping_root_menu" action="azmee_vehicle_type_action_view" sequence="40"/>
</odoo>