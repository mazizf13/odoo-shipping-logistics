<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="azmee_vehicle_form_view" model="ir.ui.view">
            <field name="name">azmee.vehicle.form.view</field>
            <field name="model">azmee.vehicle</field>
            <field name="arch" type="xml">
                <form string="Vehicle">
                    <sheet>
                        <group>
                            <div class="oe_title">
                                <label for="name" class="oe_edit_only"/>
                                <h1>
                                    <field name="name" placeholder="......"/>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <group>
                                <field name="registration_number"/>
                                <field name="tyre_number"/>
                                <field name="km"/>
                                <field name="active"/>
                                <field name="tax_expiry_date"/>
                                <field name="last_inspection_time"/>
                                <field name="condition"/>
                            </group>
                            <group>
                                <field name="notes"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="brand_id"/>
                                <field name="model_id"/>
                                <field name="year_manufacture"/>
                                <field name="type_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="azmee_vehicle_list_view" model="ir.ui.view">
            <field name="name">azmee.vehicle.list.view</field>
            <field name="model">azmee.vehicle</field>
            <field name="arch" type="xml">
                <list string="Vehicle">
                    <field name="name"/>
                    <field name="registration_number"/>
                    <field name="last_inspection_time"/>
                    <field name="condition"/>
                </list>
            </field>
        </record>

        <record id="azmee_vehicle_action_view" model="ir.actions.act_window">
            <field name="name">Vehicle</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">azmee.vehicle</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                There is no vehicle!
              </p><p>
                Click create to add one.
              </p>
            </field>
        </record>

        <menuitem id="azmee_shipping_root_menu" name="Shipping" sequence="10"/>
        <menuitem id="master_data_menu" name="Master Data" parent="azmee_shipping_root_menu" sequence="10"/>
        <menuitem id="azmee_vehicle_menu" name="Vehicle" parent="master_data_menu" action="azmee_vehicle_action_view" sequence="10"/>
    </data>
</odoo>