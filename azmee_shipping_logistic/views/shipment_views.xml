<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="azmee_shipment_form_view" model="ir.ui.view">
          <field name="name">azmee.shipment.form.view</field>
          <field name="model">azmee.shipment</field>
          <field name="arch" type="xml">
              <form string="Shipment">
                  <header>
                      <button name="action_confirm" string="Confirm" class="oe_highlight" invisible="state != 'draft'" type="object"/>
                      <button name="action_done" string="Done" class="oe_highlight" invisible="state != 'confirm'" type="object"/>
                      <button name="action_cancel" string="Cancel" class="oe_highlight" invisible="state != 'confirm'" type="object"/>
                      <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done"/>
                  </header>
                  <sheet>
                      <div class="oe_title">
                          <label for="name" class="oe_edit_only"/>
                          <h1>
                              <field name="name" placeholder="......"/>
                          </h1>
                      </div>
                      <group>
                          <group>
                              <field name="driver_name" readonly="state != 'draft'"/>
                              <field name="vehicle_id" readonly="state != 'draft'"/>
                          </group>
                          <group>
                              <field name="departure_date" readonly="state != 'draft'"/>
                          </group>
                      </group>
                      <group>
                          <field name="line_ids" readonly="state not in ['draft', 'confirm']" nolabel="1">
                              <list editable="bottom">
                                  <field name="pl_issue_id" readonly="state != 'draft'"/>
                                  <field name="state"/>
                              </list>
                          </field>
                      </group>
                  </sheet>
              </form>
          </field>
        </record>

        <record id="azmee_shipment_list_view" model="ir.ui.view">
            <field name="name">azmee.shipment.list.view</field>
            <field name="model">azmee.shipment</field>
            <field name="arch" type="xml">
                <list string="Shipment">
                    <field name="name"/>
                    <field name="driver_name"/>
                    <field name="vehicle_id"/>
                    <field name="departure_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="azmee_shipment_action_view" model="ir.actions.act_window">
            <field name="name">Shipment</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">azmee.shipment</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="shipment_menu" name="Shipment" parent="dokumen_menu" action="azmee_shipment_action_view" sequence="30"/>
    </data>
</odoo>