<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="spb_form_view" model="ir.ui.view">
            <field name="name">spb.form.view</field>
            <field name="model">azmee.spb</field>
            <field name="arch" type="xml">
                <form string="SPB">
                    <header>
                        <button name="action_confirm" string="Confirm" class="oe_highlight" invisible="state != 'draft'" type="object"/>
                        <button name="action_approve" string="Approve" class="oe_highlight" invisible="state != 'confirm'" type="object"/>
                        <button name="action_reject" string="Reject" invisible="state != 'confirm'" type="object"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirm,approve"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="......"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="warehouse_from_id" readonly="state != 'draft'"/>
                                <field name="warehouse_to_id" readonly="state != 'draft'"/>
                            </group>
                             <group>
                                <field name="transfer_date" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <field name="line_ids" nolabel="1" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="spb_list_view" model="ir.ui.view">
            <field name="name">spb.list.view</field>
            <field name="model">azmee.spb</field>
            <field name="arch" type="xml">
                <list string="SPB">
                    <field name="name"/>
                    <field name="transfer_date"/>
                    <field name="warehouse_from_id"/>
                    <field name="warehouse_to_id"/>
                    <field name="total_qty"/>
                </list>
            </field>
        </record>

        <record id="spb_search_view" model="ir.ui.view">
           <field name="name">spb.search.view</field>
           <field name="model">azmee.spb</field>
            <field name="arch" type="xml">
                <search string="SPB">
                    <field name="name"/>
                    <field name="warehouse_from_id"/>
                    <field name="warehouse_to_id"/>
                </search>
           </field>
        </record>

        <record id="spb_action_view" model="ir.actions.act_window">
            <field name="name">SPB</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">azmee.spb</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="dokumen_menu" name="Dokumen" parent="azmee_shipping_root_menu" sequence="20"/>
        <menuitem id="spb_menu" name="SPB" parent="azmee_shipping_root_menu" action="spb_action_view" sequence="10"/>
    </data>
</odoo>