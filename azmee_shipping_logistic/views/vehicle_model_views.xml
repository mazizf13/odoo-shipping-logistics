<?xml version="1.0" encoding="utf8" ?>
<odoo>
    <record id="azmee_vehicle_model_form_view" model="ir.ui.view">
        <field name="name">azmee.vehicle.model.form.view</field>
        <field name="model">azmee.vehicle.model</field>
        <field name="arch" type="xml">
            <form string="Model">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="azmee_vehicle_model_list_view" model="ir.ui.view">
        <field name="name">azmee.vehicle.model.list.view</field>
        <field name="model">azmee.vehicle.model</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="azmee_vehicle_model_action_view" model="ir.actions.act_window">
        <field name="name">Model</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">azmee.vehicle.model</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                There is no vehicle model!
              </p><p>
                Click create to add one.
              </p>
            </field>
    </record>

    <menuitem id="azmee_vehicle_model_menu" name="Model" parent="azmee_shipping_root_menu" action="azmee_vehicle_model_action_view" sequence="30"/>
</odoo>