<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_azmee_shipment" model="ir.module.category">
            <field name="name">Shipping</field>
            <field name="sequence">5</field>
            <field name="exclusive" eval="False"/>
        </record>

        <record id="group_azmee_shipping_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_azmee_shipping_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="implied_ids" eval="[(4, ref('group_azmee_shipping_user'))]"/>
        </record>

        <record id="privilege_azmee_shipment" model="res.groups.privilege">
            <field name="name">Shipping Access</field>
            <field name="category_id" ref="module_category_azmee_shipment"/>
            <field name="group_ids" eval="[(6, 0, [ref('group_azmee_shipping_user'), ref('group_azmee_shipping_manager')])]"/>
        </record>

        <record id="vehicle_rule_user" model="ir.rule">
            <field name="name">vehicle.rule.user</field>
            <field name="model_id" ref="model_azmee_vehicle"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_azmee_shipping_user'))]"/>
        </record>
        <record id="vehicle_rule_admin" model="ir.rule">
            <field name="name">vehicle.rule.admin</field>
            <field name="model_id" ref="model_azmee_vehicle"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_azmee_shipping_manager'))]"/>
        </record>

    </data>
</odoo>