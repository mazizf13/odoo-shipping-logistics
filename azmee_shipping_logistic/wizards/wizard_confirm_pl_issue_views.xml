<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="wizard_confirm_pl_issue_form_view" model="ir.ui.view">
            <field name="name">wizard.confirm.pl.issue.form.view</field>
            <field name="model">wizard.confirm.pl.issue</field>
            <field name="arch" type="xml">
                <form string="Confirmation PL Issue">
                    <sheet>
                        <group>
                            <field name="pl_issue_id" readonly="1" force_save="1"/>
                            <field name="warehouse_from_id"/>
                            <field name="warehouse_to_id"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Confirm" class="btn-primary" type="object" data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>