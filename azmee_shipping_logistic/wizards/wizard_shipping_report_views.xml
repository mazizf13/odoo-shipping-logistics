<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="wizard_shipping_report_form_view" model="ir.ui.view">
            <field name="name">wizard.shipping.report.form.view</field>
            <field name="model">wizard.shipping.report</field>
            <field name="arch" type="xml">
                <form string="Shipping Report">
                    <sheet>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_print" string="Print" class="btn-primary" type="object" data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="wizard_shipping_report_action_view" model="ir.actions.act_window">
            <field name="name"></field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">wizard.shipping.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="report_menu" name="Reporting" parent="azmee_shipping_root_menu" sequence="50"/>
        <menuitem id="wizard_shipping_report_menu" name="Shipping Report" parent="report_menu" action="wizard_shipping_report_action_view" sequence="10"/>
    </data>
</odoo>